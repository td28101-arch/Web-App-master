# Add ALL of these variables in Netlify Site configuration > Environment variables

# SoSoValue API - required for live market / index / ETF / news data
SOSOVALUE_API_KEY=your_sosovalue_key
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1

# SoDEX API - required for live account / order features
SODEX_NETWORK=mainnet
SODEX_API_KEY_NAME=api-key-01
SODEX_API_PRIVATE_KEY=0x...
SODEX_ACCOUNT_ID=
SODEX_CHAIN_ID=286623

# Optional: only use this if SoDEX changes the endpoint or you want to force testnet/mainnet manually
# SODEX_REST_BASE=https://mainnet-gw.sodex.dev/api/v1/perps
